# Gonep Patient Portal — environment example
# DO NOT edit this file directly. Copy to .env and fill in values.
# Switch modes using npm scripts — never edit .env manually.
#
# npm run start          → mock (default, no backend needed)
# npm run start:dev      → development (local backend)
# npm run start:staging  → staging server
# npm run start:prod     → production server
EXPO_PUBLIC_API_MODE=mock
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_PATIENT_BASE_PATH=/api/v1/patient
EXPO_PUBLIC_APP_NAME=Gonep Patient Portal
EXPO_PUBLIC_DEMO_EMAIL=your-demo-email@example.com
EXPO_PUBLIC_DEMO_PASSWORD=your-demo-password
EXPO_PUBLIC_API_TIMEOUT_MS=15000
