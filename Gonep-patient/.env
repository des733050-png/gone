# Fallback environment values.
# Expo loads this file last (lowest priority) in all modes.
# For mock mode use: npm run start:mock  or  npm run web:mock
# This file's values only apply when a key is not already defined by a named .env.* file.
EXPO_PUBLIC_API_MODE=mock
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_PATIENT_BASE_PATH=/api/v1/patient
EXPO_PUBLIC_APP_NAME=Gonep Patient Portal
EXPO_PUBLIC_DEMO_EMAIL=patient@gonep.co.ke
EXPO_PUBLIC_DEMO_PASSWORD=password123
EXPO_PUBLIC_API_TIMEOUT_MS=15000
